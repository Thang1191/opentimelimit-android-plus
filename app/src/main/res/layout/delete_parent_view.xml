<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="userName"
            type="String" />

        <variable
            name="canDelete"
            type="boolean" />

        <variable
            name="currentStatus"
            type="String" />

        <variable
            name="isWorking"
            type="boolean" />

        <import type="android.view.View" />
    </data>

    <com.google.android.material.card.MaterialCardView
        style="?attr/materialCardViewFilledStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp"
        app:cardBackgroundColor="?attr/colorErrorContainer"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/manage_parent_remove_user_title"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnErrorContainer" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{@string/manage_parent_remove_user_text(userName)}"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnErrorContainer"
                tools:text="Are you sure you want to delete this user?" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@{currentStatus}"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorError"
                tools:text="Ready to delete" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/user_password_layout"
                style="?attr/textInputOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:hint="@string/login_password_hint"
                android:visibility="@{canDelete ? View.VISIBLE : View.GONE}"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/user_password_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="@{!isWorking}"
                    android:inputType="textPassword" />

            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/confirm_delete_button"
                style="?attr/materialButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="24dp"
                android:backgroundTint="?attr/colorError"
                android:enabled="@{!isWorking}"
                android:text="@string/generic_delete"
                android:textColor="?attr/colorOnError"
                android:visibility="@{canDelete ? View.VISIBLE : View.GONE}" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</layout>
