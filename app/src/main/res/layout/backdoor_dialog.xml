<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="enableButtons"
            type="boolean" />

        <variable
            name="nonce"
            type="String" />

        <variable
            name="input"
            type="String" />

        <variable
            name="handlers"
            type="io.timelimit.android.ui.backdoor.BackdoorDialogListener" />
    </data>

    <ViewFlipper
        android:id="@+id/flipper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Intro Step -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backdoor_intro_text"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface" />

            <Button
                android:id="@+id/intro_confirm_button"
                style="?attr/materialButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="24dp"
                android:text="@string/backdoor_intro_confirm" />

        </LinearLayout>

        <!-- Input Step -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backdoor_instruction_1"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@{nonce}"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="monospace"
                tools:text="ABCD-EFGH-IJKL" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backdoor_instruction_2"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="start"
                android:singleLine="true"
                android:text="@{input}"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorSecondary"
                android:fontFamily="monospace"
                tools:text="0123-4567" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexDirection="row"
                app:flexWrap="wrap"
                app:justifyContent="center">

                <!-- Generate buttons dynamically or keep them if needed. Keeping them for simplicity but with M3 style -->
                <!-- Reuse keyboard_btn.xml logic or just style them here -->
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(0)}" android:enabled="@{enableButtons}" android:text="0" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(1)}" android:enabled="@{enableButtons}" android:text="1" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(2)}" android:enabled="@{enableButtons}" android:text="2" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(3)}" android:enabled="@{enableButtons}" android:text="3" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(4)}" android:enabled="@{enableButtons}" android:text="4" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(5)}" android:enabled="@{enableButtons}" android:text="5" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(6)}" android:enabled="@{enableButtons}" android:text="6" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(7)}" android:enabled="@{enableButtons}" android:text="7" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(8)}" android:enabled="@{enableButtons}" android:text="8" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(9)}" android:enabled="@{enableButtons}" android:text="9" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(10)}" android:enabled="@{enableButtons}" android:text="A" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(11)}" android:enabled="@{enableButtons}" android:text="B" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(12)}" android:enabled="@{enableButtons}" android:text="C" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(13)}" android:enabled="@{enableButtons}" android:text="D" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(14)}" android:enabled="@{enableButtons}" android:text="E" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.onButtonClicked(15)}" android:enabled="@{enableButtons}" android:text="F" />
                <Button style="?attr/materialButtonTonalStyle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="2dp" android:minWidth="60dp" android:onClick="@{() -> handlers.removeLastChar()}" android:enabled="@{enableButtons}" android:text="&lt;" />

            </com.google.android.flexbox.FlexboxLayout>

        </LinearLayout>
    </ViewFlipper>
</layout>
