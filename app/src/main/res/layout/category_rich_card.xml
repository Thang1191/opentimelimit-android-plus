<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="title"
            type="String" />

        <variable
            name="usedTimeToday"
            type="String" />

        <variable
            name="remainingTimeToday"
            type="String" />

        <variable
            name="usedForAppsWithoutCategory"
            type="boolean" />

        <variable
            name="isTemporarilyBlocked"
            type="boolean" />

        <variable
            name="temporarilyBlockedUntil"
            type="String" />

        <variable
            name="limitsDisabledUntil"
            type="String" />

        <import type="android.text.TextUtils" />
        <import type="android.view.View" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/left_space"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card"
            style="?attr/materialCardViewElevatedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@{title}"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="?attr/colorOnSurface"
                        tools:text="Allowed Apps" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/manage_child_category_for_unassigned_apps"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorPrimary"
                        android:visibility="@{usedForAppsWithoutCategory ? View.VISIBLE : View.GONE}" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="@{TextUtils.isEmpty(usedTimeToday) &amp;&amp; TextUtils.isEmpty(remainingTimeToday) ? View.GONE : View.VISIBLE}">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@{usedTimeToday}"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:visibility="@{TextUtils.isEmpty(usedTimeToday) ? View.GONE : View.VISIBLE}"
                            tools:text="Used: 2 minutes" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@{remainingTimeToday}"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:visibility="@{TextUtils.isEmpty(remainingTimeToday) ? View.GONE : View.VISIBLE}"
                            tools:text="Remaining: 5 minutes" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/manage_child_category_no_time_limits"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="@{TextUtils.isEmpty(remainingTimeToday) ? View.VISIBLE : View.GONE}" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="@{isTemporarilyBlocked || !TextUtils.isEmpty(limitsDisabledUntil) ? View.VISIBLE : View.GONE}">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:drawableStart="@drawable/ic_lock_outline_black_24dp"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@{TextUtils.isEmpty(temporarilyBlockedUntil) ? @string/overview_user_item_temporarily_blocked : @string/overview_user_item_temporarily_blocked_until(temporarilyBlockedUntil)}"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorError"
                            android:visibility="@{isTemporarilyBlocked ? View.VISIBLE : View.GONE}"
                            app:drawableTint="?attr/colorError"
                            tools:ignore="UnusedAttribute"
                            tools:text="Temporarily Blocked" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_alarm_off_black_24dp"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:text="@{@string/overview_user_item_temporarily_disabled_until(limitsDisabledUntil)}"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorSecondary"
                            android:visibility="@{TextUtils.isEmpty(limitsDisabledUntil) ? View.GONE : View.VISIBLE}"
                            app:drawableTint="?attr/colorSecondary"
                            tools:ignore="UnusedAttribute"
                            tools:text="Limits disabled until..." />
                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/category_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</layout>
