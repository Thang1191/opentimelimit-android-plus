<layout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
         <variable
            name="showCustomKeyboard"
            type="boolean" />
        <variable
            name="biometricAuthEnabled"
            type="boolean" />
        <variable
            name="randomChallenge"
            type="String" />

        <import type="android.view.View" />
        <import type="android.text.TextUtils" />
    </data>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Password mode: shown when randomChallenge is null -->
        <TextView
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:text="@string/login_dialog_password_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="@{TextUtils.isEmpty(randomChallenge) ? View.VISIBLE : View.GONE}" />

        <!-- Challenge mode: shown when randomChallenge is not null -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="@{TextUtils.isEmpty(randomChallenge) ? View.GONE : View.VISIBLE}">

            <TextView
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface"
                android:text="@string/random_unlock_challenge_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/challenge_display"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:textSize="28sp"
                android:typeface="monospace"
                android:letterSpacing="0.25"
                android:textStyle="bold"
                android:text="@{randomChallenge}"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center" />

        </LinearLayout>

        <!-- Challenge input field: shown when challenge mode -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"
            android:visibility="@{TextUtils.isEmpty(randomChallenge) ? View.GONE : View.VISIBLE}">

            <com.google.android.material.textfield.TextInputLayout
                style="?attr/textInputOutlinedStyle"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/random_unlock_challenge_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:imeOptions="actionGo"
                    android:inputType="textVisiblePassword"
                    android:id="@+id/challenge_input"
                    android:fontFamily="monospace"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Password input: shown when normal password mode -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"
            android:visibility="@{TextUtils.isEmpty(randomChallenge) ? View.VISIBLE : View.GONE}">

            <com.google.android.material.textfield.TextInputLayout
                style="?attr/textInputOutlinedStyle"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/login_password_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:imeOptions="actionGo"
                    android:inputType="textPassword"
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageView
                app:tint="?attr/colorOnSurface"
                android:background="?selectableItemBackground"
                android:id="@+id/show_keyboard_button"
                android:src="@drawable/ic_keyboard_black_24dp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="12dp" />

            <ImageView
                android:id="@+id/biometric_auth_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?selectableItemBackground"
                android:contentDescription="@string/biometric_login_button_description"
                android:src="@drawable/ic_fingerprint_24dp"
                android:layout_marginStart="8dp"
                android:padding="12dp"
                app:tint="?attr/colorOnSurface"
                android:visibility="@{biometricAuthEnabled ? View.VISIBLE : View.GONE}" />

        </LinearLayout>

        <io.timelimit.android.ui.view.KeyboardView
            android:visibility="@{showCustomKeyboard ? View.VISIBLE : View.GONE}"
            android:id="@+id/keyboard"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</layout>
